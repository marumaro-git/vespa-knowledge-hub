# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required permissions: repo (Full control of private repositories)
GITHUB_TOKEN=ghp_your_token_here

# Target repositories to index (comma-separated)
# Format: owner/repo1,owner/repo2
TARGET_REPOS=owner/repo1,owner/repo2

# Vespa configuration
VESPA_URL=http://localhost:8080

# API Server configuration
API_PORT=3000

# Optional: Rate limiting
# GitHub API rate limit is 5000 requests/hour for authenticated requests
MAX_REQUESTS_PER_HOUR=4000

# Optional: Indexing options
# Maximum file size to index (in bytes, default: 1MB)
MAX_FILE_SIZE=1048576

# Skip binary files
SKIP_BINARY_FILES=true

# File extensions to skip (comma-separated)
SKIP_EXTENSIONS=.png,.jpg,.jpeg,.gif,.svg,.ico,.woff,.woff2,.ttf,.eot,.pdf,.zip,.tar,.gz
